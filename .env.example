# MongoDB — si provisionás Atlas desde el Marketplace de Vercel, esta variable
# se completa sola en el proyecto (no hace falta cargarla a mano ahí).
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/eli

# Auth — genera un secreto largo y random, ej: openssl rand -base64 48
AUTH_SECRET=

# Vercel Blob — se completa sola al conectar un Blob Store desde el dashboard
# del proyecto en Vercel (Storage → Create Database → Blob). En local, corré
# `vercel env pull .env.local` después de linkear el proyecto para traerla.
BLOB_READ_WRITE_TOKEN=
